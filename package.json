{
  "name": "example-graph",
  "version": "0.0.1",
  "description": "A starter template for creating a LangGraph workflow.",
  "packageManager": "yarn@1.22.22",
  "main": "dist/index.js",
  "author": "Your Name",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "clean": "node -e \"import('fs').then(fs=>fs.rmSync('dist',{recursive:true,force:true}))\"",
    "start": "node dist/index.js",
    "dev": "npx @langchain/langgraph-cli dev",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=\\.test\\.ts$ --testPathIgnorePatterns=\\.int\\.test\\.ts$",
    "test:int": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=\\.int\\.test\\.ts$",
    "format": "prettier --write .",
    "lint": "eslint src",
    "format:check": "prettier --check .",
    "lint:langgraph-json": "node scripts/checkLanggraphPaths.js",
    "lint:all": "yarn lint && yarn lint:langgraph-json && yarn format:check",
    "test:all": "yarn test && yarn test:int && yarn lint:langgraph-json",
    "linkedin:auth": "npm run build && node dist/oauth/runAuth.js linkedin",
    "linkedin:doctor": "npm run build && node dist/oauth/linkedinDoctor.js doctor",
    "linkedin:test-post": "npm run build && node dist/oauth/linkedinDoctor.js test-post",
    "auth": "npm run build && node dist/oauth/runAuth.js",
    "auth:status": "npm run build && node dist/oauth/runAuth.js status",
    "auth:threads": "node scripts/threads-token.mjs",
    "auth:facebook": "node scripts/facebook-token.mjs",
    "test:meta": "node scripts/meta-test-post.mjs",
    "test:x": "node scripts/x-test-post.mjs",
    "canonical:list": "npm run build && node scripts/canonical-cli.mjs list",
    "canonical:show": "npm run build && node scripts/canonical-cli.mjs show",
    "canonical:regen": "npm run build && node scripts/canonical-cli.mjs regen",
    "tokens:status": "npm run build && node scripts/tokens-status.mjs",
    "tokens:refresh": "npm run build && node scripts/tokens-status.mjs --refresh",
    "cf:resolve": "npm run build && node scripts/cf-resolve-accounts.mjs",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "ci": "npm run build && npm run lint:langgraph-json && npm test"
  },
  "dependencies": {
    "@langchain/core": "^1.1.42",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/langgraph-sdk": "^1.9.25",
    "better-sqlite3": "^11.7.0",
    "cheerio": "^1.0.0",
    "dotenv": "^17.4.2",
    "form-data": "^4.0.6",
    "node-cron": "^4.6.0",
    "zod": "^4.4.3"
  },
  "resolutions": {
    "**/filelist/minimatch": "5.1.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^8.57.1",
    "@tsconfig/recommended": "^1.0.13",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cheerio": "^1.0.0",
    "@types/jest": "^29.5.0",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "dotenv": "^17.4.2",
    "eslint": "^8.41.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-instanceof": "^1.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  }
}

# Text: Gemini Free (primary) → Pollinations (fallback)
TEXT_PROVIDER=auto
GEMINI_API_KEY=
# Optional extra keys for Nano Banana image rotation (429 → next key)
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
# Or comma-separated: GEMINI_API_KEYS=key1,key2,key3
GEMINI_MODEL=gemini-flash-lite-latest
DAILY_GEMINI_LIMIT=80
# Pollinations AI (text fallback + image after Nano Banana)
POLLINATIONS_BASE_URL=https://gen.pollinations.ai
POLLINATIONS_API_KEY=
POLLINATIONS_TEXT_MODEL=openai-fast
# Brand face for identity-preserving covers (default: data/brand/face.jpg)
# BRAND_FACE_IMAGE=data/brand/face.jpg
# When face.jpg exists, identity providers: Nano Banana + Skywork + Pollinations (image= URL).
# Cloudflare/Horde are text-only — blocked by default when face is present.
# REQUIRE_BRAND_FACE=true
# Set false only if you accept random faces on CF/Horde when identity providers fail:
# REQUIRE_BRAND_FACE=false

# Skywork Image API — waterfall #2 after Nano Banana (multi-key rotation)
# Get keys: https://skywork.ai/?openApiKeySetting=1
SKYWORK_API_KEY=
SKYWORK_API_KEY_2=
SKYWORK_API_KEY_3=
SKYWORK_API_KEY_4=
SKYWORK_API_KEY_5=
# Or comma-separated: SKYWORK_API_KEYS=key1,key2,key3
SKYWORK_GATEWAY_URL=https://api-tools.skywork.ai/theme-gateway
# Soft cap PER KEY (UTC). Total ≈ limit × keys
DAILY_SKYWORK_LIMIT=4
SKYWORK_RESOLUTION=1K
SKYWORK_ASPECT_RATIO=1:1

# Image model when Nano Banana + Skywork fail (official: gpt-image-2)
POLLINATIONS_IMAGE_MODEL=gpt-image-2
# Face identity model when face.jpg is present (image= ref): kontext | gptimage | nanobanana
POLLINATIONS_FACE_MODEL=kontext
DAILY_POLLINATIONS_IMAGE_LIMIT=8
# Alias also accepted: IMAGE_MODEL=gpt-image-2
IMAGE_WIDTH=1024
IMAGE_HEIGHT=1024
POLLINATIONS_DAILY_REQUEST_LIMIT=1500000
IMAGE_TEMP_HOURS=24
IMGBB_API_KEY=

# Telegram (bot token — not OAuth)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL=
# Optional private chat for ops alerts (default = TELEGRAM_CHANNEL)
TELEGRAM_ALERT_CHAT=
# Inbound bot: admin sends photo/video + caption → publish to all ENABLED_PLATFORMS
# TELEGRAM_BOT_INBOUND=false to disable long-poll bot
TELEGRAM_BOT_INBOUND=true
# Your Telegram user id(s), comma-separated. DM the bot /whoami to get your id.
TELEGRAM_ADMIN_IDS=
# Warn on Telegram when token has ≤ N days left (default 1)
TOKEN_ALERT_DAYS=1
TOKEN_ALERT_ENABLED=true

# ── Unified OAuth Manager (npm run auth -- <platform>) ──
# Callback server: http://localhost:3000/auth/<platform>/callback

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/auth/linkedin/callback
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_USER_ID=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_ORGANIZATION_ID=135286337
LINKEDIN_POST_AS=person
LINKEDIN_REQUEST_ORG_SCOPE=false


# Facebook / Meta
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3000/auth/facebook/callback
FACEBOOK_PAGE_TOKEN=
FACEBOOK_PAGE_ID=

# Instagram Graph (often same Meta app)
INSTAGRAM_TOKEN=
INSTAGRAM_USER_ID=

# Threads
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=http://localhost:3000/auth/threads/callback
THREADS_TOKEN=
THREADS_USER_ID=

# X (Twitter) — OAuth 2.0 PKCE and/or OAuth 1.0a
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/auth/x/callback
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# Blogger (Google OAuth) — https://console.cloud.google.com → OAuth client
# Enable: Blogger API v3. Redirect URI must match exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BLOGGER_REDIRECT_URI=http://localhost:3000/auth/blogger/callback
BLOGGER_URL=https://istamjon.blogspot.com/
BLOGGER_ACCESS_TOKEN=
BLOGGER_REFRESH_TOKEN=
# Optional — auto-resolved from BLOGGER_URL public feed (istamjon → 6041787032258205448)
# BLOGGER_BLOG_ID=

# Database / scheduler
DB_PATH=./data/app.db
CRON_INTERVAL_MINUTES=30
DRY_RUN=false
# Try up to N articles per slot; stops after first successful publish
MAX_ARTICLES_PER_RUN=3

# Soft daily publish caps (4 posts/day policy)
DAILY_LIMIT_TELEGRAM=4
DAILY_LIMIT_LINKEDIN=4
DAILY_LIMIT_FACEBOOK=4
DAILY_LIMIT_INSTAGRAM=4
DAILY_LIMIT_X=4
DAILY_LIMIT_THREADS=4
DAILY_LIMIT_BLOGGER=4

# Image waterfall: Cloudflare free (multi-account) → AI Horde
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID_2=
CLOUDFLARE_API_TOKEN_2=
CLOUDFLARE_ACCOUNT_ID_3=
CLOUDFLARE_API_TOKEN_3=
CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-2-dev
CLOUDFLARE_IMAGE_STEPS=15
IMAGE_QUALITY=balanced
IMAGE_WIDTH=1024
IMAGE_HEIGHT=1024
# Soft cap PER Cloudflare account (neurons safety)
DAILY_IMAGE_LIMIT=2
# Soft cap TOTAL across all CF accounts
DAILY_IMAGE_TOTAL=6
# AI Horde fallback when CF free exhausted
AIHORDE_API_KEY=
DAILY_HORDE_LIMIT=4

# Schedule: random times every LOCAL day (TZ, e.g. Asia/Tashkent)
CRON_RANDOM=true
# Random slots each local day (inclusive range)
CRON_SLOTS_MIN=3
CRON_SLOTS_MAX=6
# Legacy fixed count (ignored when MIN/MAX set)
CRON_SLOTS_PER_DAY=4
CRON_WINDOW_START_HOUR=8
CRON_WINDOW_END_HOUR=21
# Min minutes between random slots (auto-shrinks if N slots cannot fit)
CRON_MIN_GAP_MINUTES=150
# Fixed times only if CRON_RANDOM=false
CRON_TIMES=09:30,19:30
# true = one run immediately on container start (catch-up still works)
CRON_RUN_ON_START=false

# Soft caps PER PLATFORM per local day — must be >= CRON_SLOTS_MAX
# (otherwise later random slots hit "Daily limit reached")
# DAILY_LIMIT_TELEGRAM=6
# DAILY_LIMIT_LINKEDIN=6
# DAILY_LIMIT_FACEBOOK=6
# DAILY_LIMIT_INSTAGRAM=6
# DAILY_LIMIT_THREADS=6

LANGSMITH_API_KEY=
